import json
import pandas as pd
import numpy as np
from pathlib import Path
from sklearn.model_selection import GroupShuffleSplit

def run_preprocessing(raw_df, workspace_path):
    workspace_path = Path(workspace_path)
    df = raw_df.copy()
    
    # Extract target before any transforms
    target = df['Credit_Score'].copy()
    
    # Drop identifier and target columns
    df.drop(columns=['ID', 'Customer_ID', 'Name', 'SSN', 'Credit_Score'], inplace=True)
    
    # Impute and clean specific columns
    df['Age'] = pd.to_numeric(df['Age'], errors='coerce').clip(lower=0)
    age_median = df['Age'].median()
    df['Age'].fillna(age_median, inplace=True)

    df['Annual_Income'] = pd.to_numeric(df['Annual_Income'], errors='coerce')
    annual_income_median = df['Annual_Income'].median()
    df['Annual_Income'].fillna(annual_income_median, inplace=True)

    df['Monthly_Inhand_Salary'].fillna(df['Monthly_Inhand_Salary'].median(), inplace=True)

    df['Num_Bank_Accounts'] = pd.to_numeric(df['Num_Bank_Accounts'], errors='coerce')
    df['Num_Bank_Accounts'].fillna(df['Num_Bank_Accounts'].median(), inplace=True)

    df['Num_Credit_Card'] = pd.to_numeric(df['Num_Credit_Card'], errors='coerce')
    df['Num_Credit_Card'].fillna(df['Num_Credit_Card'].median(), inplace=True)

    df['Interest_Rate'] = pd.to_numeric(df['Interest_Rate'], errors='coerce')
    df['Interest_Rate'].fillna(df['Interest_Rate'].median(), inplace=True)

    df['Num_of_Loan'] = pd.to_numeric(df['Num_of_Loan'], errors='coerce')
    df['Num_of_Loan'].fillna(df['Num_of_Loan'].median(), inplace=True)
    
    df['Delay_from_due_date'] = pd.to_numeric(df['Delay_from_due_date'], errors='coerce')
    df['Delay_from_due_date'].fillna(df['Delay_from_due_date'].median(), inplace=True)

    df['Num_of_Delayed_Payment'] = pd.to_numeric(df['Num_of_Delayed_Payment'], errors='coerce')
    df['Num_of_Delayed_Payment'].fillna(df['Num_of_Delayed_Payment'].median(), inplace=True)

    df['Changed_Credit_Limit'] = pd.to_numeric(df['Changed_Credit_Limit'], errors='coerce')
    df['Changed_Credit_Limit'].fillna(df['Changed_Credit_Limit'].median(), inplace=True)

    df['Num_Credit_Inquiries'].fillna(df['Num_Credit_Inquiries'].median(), inplace=True)

    df['Outstanding_Debt'] = pd.to_numeric(df['Outstanding_Debt'], errors='coerce')
    df['Outstanding_Debt'].fillna(df['Outstanding_Debt'].median(), inplace=True)

    # Convert Credit History Age to total months
    df['Credit_History_Age'] = df['Credit_History_Age'].str.extract(r'(\d+)\sYears?\sand\s(\d+)\sMonths?').astype(float)
    df['Credit_History_Age'] = df['Credit_History_Age'][0] * 12 + df['Credit_History_Age'][1]
    df['Credit_History_Age'].fillna(df['Credit_History_Age'].median(), inplace=True)

    df['Amount_invested_monthly'] = pd.to_numeric(df['Amount_invested_monthly'], errors='coerce')
    df['Amount_invested_monthly'].fillna(df['Amount_invested_monthly'].median(), inplace=True)

    df['Monthly_Balance'] = pd.to_numeric(df['Monthly_Balance'], errors='coerce')
    df['Monthly_Balance'].fillna(df['Monthly_Balance'].median(), inplace=True)

    # Impute categorical columns
    df['Month'].fillna(df['Month'].mode()[0], inplace=True)
    df['Occupation'].fillna(df['Occupation'].mode()[0], inplace=True)
    df['Credit_Mix'].fillna(df['Credit_Mix'].mode()[0], inplace=True)
    df['Payment_of_Min_Amount'].fillna(df['Payment_of_Min_Amount'].mode()[0], inplace=True)
    df['Payment_Behaviour'].fillna(df['Payment_Behaviour'].mode()[0], inplace=True)

    # Convert Month to ordinal
    month_order = {'January': 1, 'February': 2, 'March': 3, 'April': 4, 'May': 5,
                  'June': 6, 'July': 7, 'August': 8, 'September': 9,
                  'October': 10, 'November': 11, 'December': 12}
    df['Month'] = df['Month'].map(month_order)

    # Split Type_of_Loan and apply one-hot encoding
    df = df.drop(['Type_of_Loan'], axis=1).join(df['Type_of_Loan'].str.get_dummies(sep=','))

    # Apply one-hot encoding
    categorical_cols = ['Occupation', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour']
    df = pd.get_dummies(df, columns=categorical_cols, drop_first=False)

    # Save cleaned frame (before encoding)
    df.to_csv(workspace_path / 'cleaned_frame.csv', index=False)
    
    # Encode remaining categorical columns
    features = df.drop(columns=['Month'])
    
    # Save feature frame and target
    features.to_csv(workspace_path / 'feature_frame.csv', index=False)
    target.to_frame().to_csv(workspace_path / 'target.csv', index=False)
    
    # Split
    gss = GroupShuffleSplit(n_splits=1, test_size=0.2, random_state=42)
    train_idx, test_idx = next(gss.split(features, groups=raw_df['Customer_ID']))
    manifest = {'train_indices': train_idx.tolist(), 'test_indices': test_idx.tolist()}
    (workspace_path / 'split_manifest.json').write_text(json.dumps(manifest))
    
    # Report
    report = {'columns_dropped': ['ID', 'Customer_ID', 'Name', 'SSN', 'Credit_Score'], 'imputation': {
        'Age': 'median', 'Annual_Income': 'median', 'Monthly_Inhand_Salary': 'median',
        'Num_Bank_Accounts': 'median', 'Num_Credit_Card': 'median', 'Interest_Rate': 'median',
        'Num_of_Loan': 'median', 'Delay_from_due_date': 'median', 'Num_of_Delayed_Payment': 'median',
        'Changed_Credit_Limit': 'median', 'Num_Credit_Inquiries': 'median',
        'Outstanding_Debt': 'median', 'Credit_History_Age': 'median', 'Amount_invested_monthly': 'median',
        'Monthly_Balance': 'median', 'Month': 'mode', 'Occupation': 'mode',
        'Credit_Mix': 'mode', 'Payment_of_Min_Amount': 'mode', 'Payment_Behaviour': 'mode'
    }, 'encoding': {
        'Month': 'ordinal', 'Occupation': 'one_hot', 'Type_of_Loan': 'one_hot',
        'Credit_Mix': 'one_hot', 'Payment_of_Min_Amount': 'one_hot', 'Payment_Behaviour': 'one_hot'
        }, 'rows': len(df)}
    (workspace_path / 'preprocessing_report.json').write_text(json.dumps(report))

