import json
import pandas as pd
import numpy as np
from pathlib import Path
from sklearn.model_selection import GroupShuffleSplit

def run_preprocessing(raw_df, workspace_path):
    workspace_path = Path(workspace_path)
    df = raw_df.copy()

    # Extract and drop target
    target = df['Credit_Score'].copy()
    df.drop(columns=['ID', 'Customer_ID', 'SSN', 'Name', 'Credit_Score'], inplace=True)

    # Convert columns to appropriate types and handle cleaning
    df['Age'] = pd.to_numeric(df['Age'], errors='coerce')
    df['Annual_Income'] = pd.to_numeric(df['Annual_Income'], errors='coerce')
    df['Num_of_Loan'] = pd.to_numeric(df['Num_of_Loan'], errors='coerce')
    df['Num_of_Delayed_Payment'] = pd.to_numeric(df['Num_of_Delayed_Payment'], errors='coerce')
    df['Changed_Credit_Limit'] = pd.to_numeric(df['Changed_Credit_Limit'], errors='coerce')
    df['Outstanding_Debt'] = pd.to_numeric(df['Outstanding_Debt'], errors='coerce')
    df['Amount_invested_monthly'] = pd.to_numeric(df['Amount_invested_monthly'], errors='coerce')
    df['Monthly_Balance'] = pd.to_numeric(df['Monthly_Balance'], errors='coerce')

    # Extract years from 'Credit_History_Age'
    df['Credit_History_Age'] = df['Credit_History_Age'].str.extract(r'(\d+) Years')
    df['Credit_History_Age'] = pd.to_numeric(df['Credit_History_Age'], errors='coerce')

    # Impute missing values
    df['Month'].fillna(df['Month'].mode()[0], inplace=True)
    df['Age'].fillna(df['Age'].median(), inplace=True)
    df['Occupation'].fillna(df['Occupation'].mode()[0], inplace=True)
    df['Annual_Income'].fillna(df['Annual_Income'].median(), inplace=True)
    df['Monthly_Inhand_Salary'].fillna(df['Monthly_Inhand_Salary'].median(), inplace=True)
    df['Num_Bank_Accounts'].fillna(df['Num_Bank_Accounts'].median(), inplace=True)
    df['Num_Credit_Card'].fillna(df['Num_Credit_Card'].median(), inplace=True)
    df['Interest_Rate'].fillna(df['Interest_Rate'].median(), inplace=True)
    df['Num_of_Loan'].fillna(df['Num_of_Loan'].median(), inplace=True)
    df['Delay_from_due_date'].fillna(df['Delay_from_due_date'].median(), inplace=True)
    df['Num_of_Delayed_Payment'].fillna(df['Num_of_Delayed_Payment'].median(), inplace=True)
    df['Changed_Credit_Limit'].fillna(df['Changed_Credit_Limit'].median(), inplace=True)
    df['Num_Credit_Inquiries'].fillna(df['Num_Credit_Inquiries'].median(), inplace=True)
    df['Credit_Mix'].fillna(df['Credit_Mix'].mode()[0], inplace=True)
    df['Credit_History_Age'].fillna(df['Credit_History_Age'].median(), inplace=True)
    df['Payment_of_Min_Amount'].fillna(df['Payment_of_Min_Amount'].mode()[0], inplace=True)
    df['Total_EMI_per_month'].fillna(df['Total_EMI_per_month'].median(), inplace=True)
    df['Amount_invested_monthly'].fillna(df['Amount_invested_monthly'].median(), inplace=True)
    df['Payment_Behaviour'].fillna(df['Payment_Behaviour'].mode()[0], inplace=True)
    df['Monthly_Balance'].fillna(df['Monthly_Balance'].median(), inplace=True)

    # Save cleaned frame
    df.to_csv(workspace_path / 'cleaned_frame.csv', index=False)

    # Split 'Type_of_Loan' and create one-hot
    type_of_loan_dummies = df['Type_of_Loan'].str.get_dummies(sep=', ')
    df = pd.concat([df.drop(columns=['Type_of_Loan']), type_of_loan_dummies], axis=1)

    # Ordinal encoding for 'Month'
    month_order = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
    df['Month'] = df['Month'].apply(lambda x: month_order.index(x) if x in month_order else np.nan)

    # One-hot encoding for categorical columns
    df = pd.get_dummies(df, columns=['Occupation', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour'], drop_first=False)

    # Save feature frame
    df.to_csv(workspace_path / 'feature_frame.csv', index=False)

    # Save target
    target.to_frame().to_csv(workspace_path / 'target.csv', index=False)

    # Split
    gss = GroupShuffleSplit(n_splits=1, test_size=0.2, random_state=42)
    train_idx, test_idx = next(gss.split(df, groups=raw_df['Customer_ID']))
    manifest = {'train_indices': train_idx.tolist(), 'test_indices': test_idx.tolist()}
    (workspace_path / 'split_manifest.json').write_text(json.dumps(manifest))

    # Report
    report = {
        'columns_dropped': ['ID', 'Customer_ID', 'SSN', 'Name', 'Credit_Score'],
        'encoding': {
            'Month': 'ordinal',
            'Occupation': 'one_hot',
            'Type_of_Loan': 'one_hot_split',
            'Credit_Mix': 'one_hot',
            'Payment_of_Min_Amount': 'one_hot',
            'Payment_Behaviour': 'one_hot'
        },
        'imputed_values': {
            'for_mode': ['Month', 'Occupation', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour'],
            'for_median': ['Age', 'Annual_Income', 'Monthly_Inhand_Salary', 'Num_Bank_Accounts', 'Num_Credit_Card',
                           'Interest_Rate', 'Num_of_Loan', 'Delay_from_due_date', 'Num_of_Delayed_Payment',
                           'Changed_Credit_Limit', 'Num_Credit_Inquiries', 'Credit_History_Age',
                           'Total_EMI_per_month', 'Amount_invested_monthly', 'Monthly_Balance']
        },
        'rows': len(df)
    }
    (workspace_path / 'preprocessing_report.json').write_text(json.dumps(report))

