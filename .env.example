OPENAI_API_KEY=your_openai_api_key_here

# Global default model — used when no per-node override is set.
OPENAI_MODEL=gpt-4o-mini

# Per-node model overrides (optional).
# Env var pattern: OPENAI_MODEL_{CALLER} where CALLER is the node name
# uppercased with hyphens replaced by underscores.
#
# Analytical/reasoning nodes — benefit from deeper reasoning:
# OPENAI_MODEL_COLUMN_TRANSFORM_SPEC=o3
# OPENAI_REASONING_EFFORT_COLUMN_TRANSFORM_SPEC=high   # o-series only; values: low|medium|high
# OPENAI_MODEL_GENERATE_FEATURE_ENGINEERING_CODE=o4-mini
# OPENAI_MODEL_GENERATE_EDA_HYPOTHESES=o4-mini
# OPENAI_MODEL_GENERATE_TRAINING_DIAGNOSTICS=o4-mini
# OPENAI_MODEL_INTERPRET_XAI_EVIDENCE=o4-mini
# OPENAI_MODEL_REASON_HYPERPARAMETER_GRID=o4-mini
# OPENAI_MODEL_REASON_MODEL_SELECTION=o4-mini
#
# Codegen nodes — instruction-following matters more:
# OPENAI_MODEL_GENERATE_PREPROCESSING_CODE=gpt-4o
#
# Repair nodes — diagnosing bugs from audit feedback is analytical reasoning:
# OPENAI_MODEL_REPAIR_PREPROCESSING_CODE=o4-mini
# OPENAI_MODEL_REPAIR_FEATURE_ENGINEERING_CODE=gpt-4o
#
# Spec nodes (structured output, low complexity):
# OPENAI_MODEL_DATASET_POLICY_SPEC=gpt-4o-mini
#
# Business text nodes — simple generation:
# OPENAI_MODEL_RECOMMEND_ACTION=gpt-4o-mini
