import json
import pandas as pd
import numpy as np
from pathlib import Path
from sklearn.model_selection import GroupShuffleSplit

def run_preprocessing(raw_df, workspace_path):
    workspace_path = Path(workspace_path)
    df = raw_df.copy()

    # Extract target before any transforms
    target = df['Credit_Score'].copy()

    # Drop identifier and target columns
    df.drop(columns=['ID', 'Customer_ID', 'SSN', 'Name', 'Credit_Score'], inplace=True)

    # Clean and impute columns
    df['Age'] = pd.to_numeric(df['Age'], errors='coerce').clip(lower=0)
    df['Age'].fillna(df['Age'].median(), inplace=True)

    df['Annual_Income'] = pd.to_numeric(df['Annual_Income'], errors='coerce')
    df['Annual_Income'].fillna(df['Annual_Income'].median(), inplace=True)

    df['Monthly_Inhand_Salary'].fillna(df['Monthly_Inhand_Salary'].median(), inplace=True)

    df['Num_Bank_Accounts'] = df['Num_Bank_Accounts'].fillna(df['Num_Bank_Accounts'].median())
    df['Num_Credit_Card'] = df['Num_Credit_Card'].fillna(df['Num_Credit_Card'].median())

    df['Num_of_Loan'] = pd.to_numeric(df['Num_of_Loan'], errors='coerce').fillna(df['Num_of_Loan'].median()).astype(int)
    
    df['Num_of_Delayed_Payment'] = pd.to_numeric(df['Num_of_Delayed_Payment'], errors='coerce').fillna(df['Num_of_Delayed_Payment'].median()).astype(int)

    df['Changed_Credit_Limit'] = pd.to_numeric(df['Changed_Credit_Limit'], errors='coerce')
    df['Changed_Credit_Limit'].fillna(df['Changed_Credit_Limit'].median(), inplace=True)

    df['Num_Credit_Inquiries'].fillna(df['Num_Credit_Inquiries'].median(), inplace=True)

    df['Outstanding_Debt'] = pd.to_numeric(df['Outstanding_Debt'], errors='coerce')
    df['Outstanding_Debt'].fillna(df['Outstanding_Debt'].median(), inplace=True)

    df['Credit_Utilization_Ratio'].fillna(df['Credit_Utilization_Ratio'].median(), inplace=True)

    df[['Years', 'Months']] = df['Credit_History_Age'].str.extract(r'(\d+) Years and (\d+) Months').astype(float)
    df['Credit_History_Age'] = (df['Years'] * 12 + df['Months']).fillna(df[['Years', 'Months']].mean().sum())
    df.drop(columns=['Years', 'Months'], inplace=True)

    df['Total_EMI_per_month'].fillna(df['Total_EMI_per_month'].median(), inplace=True)

    df['Amount_invested_monthly'] = pd.to_numeric(df['Amount_invested_monthly'], errors='coerce')
    df['Amount_invested_monthly'].fillna(df['Amount_invested_monthly'].median(), inplace=True)

    df['Monthly_Balance'] = pd.to_numeric(df['Monthly_Balance'], errors='coerce')
    df['Monthly_Balance'].fillna(df['Monthly_Balance'].median(), inplace=True)

    # Fill categorical columns with mode
    categorical_cols = ['Month', 'Occupation', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour']
    for col in categorical_cols:
        df[col].fillna(df[col].mode()[0], inplace=True)

    # Save cleaned frame (before encoding)
    df.to_csv(workspace_path / 'cleaned_frame.csv', index=False)

    # One-hot encoding
    df = pd.get_dummies(df, columns=['Month', 'Occupation', 'Type_of_Loan', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour'])

    # Save feature frame and target
    df.to_csv(workspace_path / 'feature_frame.csv', index=False)
    target.to_frame().to_csv(workspace_path / 'target.csv', index=False)

    # Split
    gss = GroupShuffleSplit(n_splits=1, test_size=0.2, random_state=42)
    group_column = raw_df['Customer_ID']
    train_idx, test_idx = next(gss.split(df, target, groups=group_column))
    manifest = {'train_indices': train_idx.tolist(), 'test_indices': test_idx.tolist()}
    (workspace_path / 'split_manifest.json').write_text(json.dumps(manifest))

    # Report
    report = {
        'columns_dropped': ['ID', 'Customer_ID', 'SSN', 'Name', 'Credit_Score'],
        'rows': len(df),
        'imputation': {
            'Age': 'median',
            'Annual_Income': 'median',
            'Monthly_Inhand_Salary': 'median',
            'Num_of_Loan': 'median',
            'Num_of_Delayed_Payment': 'median',
            'Changed_Credit_Limit': 'median',
            'Outstanding_Debt': 'median',
            'Credit_History_Age': 'average of extracted components',
            'Amount_invested_monthly': 'median',
            'Monthly_Balance': 'median'
        },
        'encoding': ['one-hot'],
        'categorical_imputation': 'mode'
    }
    (workspace_path / 'preprocessing_report.json').write_text(json.dumps(report))

