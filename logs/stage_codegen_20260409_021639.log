import json
import pandas as pd
import numpy as np
from pathlib import Path
from sklearn.model_selection import GroupShuffleSplit

def convert_credit_history_age(age_str):
    if pd.isna(age_str):
        return np.nan
    years_months = age_str.split(' ')
    years = int(years_months[0]) if 'Years' in age_str else 0
    months = int(years_months[2]) if 'Months' in age_str else 0
    return years * 12 + months

def run_preprocessing(raw_df, workspace_path):
    workspace_path = Path(workspace_path)
    df = raw_df.copy()
    
    # Extract target before any transforms
    target = df['Credit_Score'].copy()
    
    # Drop identifier and target columns
    df = df.drop(columns=['ID', 'Customer_ID', 'SSN', 'Name', 'Credit_Score'])
    
    # Impute missing values
    df['Month'] = df['Month'].fillna(df['Month'].mode()[0])
    df['Occupation'] = df['Occupation'].fillna(df['Occupation'].mode()[0])
    df['Monthly_Inhand_Salary'] = df['Monthly_Inhand_Salary'].fillna(df['Monthly_Inhand_Salary'].median())
    df['Num_of_Delayed_Payment'] = pd.to_numeric(df['Num_of_Delayed_Payment'], errors='coerce')
    df['Num_of_Delayed_Payment'] = df['Num_of_Delayed_Payment'].fillna(df['Num_of_Delayed_Payment'].median())
    df['Credit_History_Age'] = df['Credit_History_Age'].apply(convert_credit_history_age)
    df['Credit_History_Age'] = df['Credit_History_Age'].fillna(df['Credit_History_Age'].median())
    df['Type_of_Loan'] = df['Type_of_Loan'].fillna(df['Type_of_Loan'].mode()[0])
    df['Amount_invested_monthly'] = pd.to_numeric(df['Amount_invested_monthly'], errors='coerce')
    df['Amount_invested_monthly'] = df['Amount_invested_monthly'].fillna(df['Amount_invested_monthly'].median())
    df['Monthly_Balance'] = pd.to_numeric(df['Monthly_Balance'], errors='coerce')
    df['Monthly_Balance'] = df['Monthly_Balance'].fillna(df['Monthly_Balance'].median())
    df['Num_Credit_Inquiries'] = df['Num_Credit_Inquiries'].fillna(df['Num_Credit_Inquiries'].median())
    
    # Convert and clean specific columns
    df['Age'] = pd.to_numeric(df['Age'], errors='coerce').clip(lower=0)
    df['Age'] = df['Age'].fillna(df['Age'].median())
    df['Annual_Income'] = pd.to_numeric(df['Annual_Income'], errors='coerce')
    df['Annual_Income'] = df['Annual_Income'].fillna(df['Annual_Income'].median())
    df['Num_of_Loan'] = pd.to_numeric(df['Num_of_Loan'], errors='coerce')
    df['Num_of_Loan'] = df['Num_of_Loan'].fillna(df['Num_of_Loan'].median())
    df['Changed_Credit_Limit'] = pd.to_numeric(df['Changed_Credit_Limit'].replace('_', np.nan), errors='coerce')
    df['Changed_Credit_Limit'] = df['Changed_Credit_Limit'].fillna(df['Changed_Credit_Limit'].median())
    df['Outstanding_Debt'] = pd.to_numeric(df['Outstanding_Debt'], errors='coerce')
    df['Outstanding_Debt'] = df['Outstanding_Debt'].fillna(df['Outstanding_Debt'].median())

    # Save cleaned frame (before encoding)
    df.to_csv(workspace_path / 'cleaned_frame.csv', index=False)
    
    # One-hot encode categorical features
    df = pd.get_dummies(df, columns=['Month', 'Occupation', 'Type_of_Loan', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour'], drop_first=False)
    
    # Save feature frame and target
    df.to_csv(workspace_path / 'feature_frame.csv', index=False)
    target.to_frame().to_csv(workspace_path / 'target.csv', index=False)
    
    # Split
    gss = GroupShuffleSplit(n_splits=1, test_size=0.2, random_state=42)
    groups = raw_df['Customer_ID']
    train_idx, test_idx = next(gss.split(df, y=target, groups=groups))
    manifest = {'train_indices': train_idx.tolist(), 'test_indices': test_idx.tolist()}
    (workspace_path / 'split_manifest.json').write_text(json.dumps(manifest))
    
    # Report
    report = {
        'columns_dropped': ['ID', 'Customer_ID', 'SSN', 'Name', 'Credit_Score'],
        'imputation': {
            'Monthly_Inhand_Salary': 'median',
            'Num_of_Delayed_Payment': 'median',
            'Credit_History_Age': 'converted and median',
            'Amount_invested_monthly': 'median',
            'Monthly_Balance': 'median',
            'Num_Credit_Inquiries': 'median',
            'Age': 'converted and median',
            'Annual_Income': 'converted and median',
            'Num_of_Loan': 'converted and median',
            'Changed_Credit_Limit': 'converted and median',
            'Outstanding_Debt': 'converted and median',
            'Month': 'mode',
            'Occupation': 'mode',
            'Type_of_Loan': 'mode'
        },
        'encoding': {
            'One_hot_encoded': ['Month', 'Occupation', 'Type_of_Loan', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour']
        },
        'rows': len(df)
    }
    (workspace_path / 'preprocessing_report.json').write_text(json.dumps(report))

